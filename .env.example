OPENAI_API_KEY=
OPENAI_PROMPT_CACHE_RETENTION=in_memory
# Optional. Most public hosts provide PORT automatically.
# PORT=4173

# Google Sign-In (required for login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=
# Public origin used for OAuth redirect URIs (no trailing slash)
APP_BASE_URL=http://localhost:4173
